{
  "mcpServers": {
    "gmail": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@gongrzhe/server-gmail-autoauth-mcp"]
    },
    "sqlite": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "mcp-server-sqlite-npx", "./enron.db"]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer YOUR_GITHUB_PAT_HERE"
      }
    }
  }
}
